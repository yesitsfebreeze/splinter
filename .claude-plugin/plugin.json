{
  "name": "scratch",
  "version": "0.1.2",
  "description": "Fn-level code index MCP server. Splits source files into per-function body files for token-efficient navigation, with a persistent per-file scratch note for agent memory. Watcher re-splits on source change.",
  "author": {
    "name": "febreeze",
    "url": "https://github.com/yesitsfebreeze"
  },
  "homepage": "https://github.com/yesitsfebreeze/scratch",
  "repository": "https://github.com/yesitsfebreeze/scratch",
  "license": "MIT",
  "keywords": [
    "mcp",
    "index",
    "code-navigation",
    "token-efficient",
    "rust",
    "scratch",
    "memory"
  ],
  "mcpServers": {
    "scratch": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/scratch",
      "args": [],
      "env": {
        "SCRATCH_EXT": "rs",
        "SCRATCH_SRC_DIR": "src",
        "SCRATCH_DEBOUNCE_MS": "120000",
        "SCRATCH_MAX_LOC": "256"
      }
    }
  },
  "skills": "./skills/"
}
